{
    "manifest_version": 3,
    "name": "Game Report 帳密自動填入",
    "version": "1.1.1",
    "description": "Auto-fills login credentials from the game-report admin tool into operator backend login forms. 搭配 game-report 後台自動填入供應商登入資訊。",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-filler.js"
            ],
            "run_at": "document_start",
            "all_frames": false
        }
    ],
    "action": {
        "default_title": "Game Report 帳密自動填入",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}
